# AWS Nitro Enclave Configuration
# Used for secure bank account verification via vsock (see collect.service.ts callAwsEnclaveViaVsock)

# Enclave CID (Context ID)
# The unique identifier for the bank verification AWS Nitro Enclave
# Example: 16
BANK_TEE_CID=

# Enclave Port
# The port the enclave listens on for verification requests
# Example: 5000
BANK_TEE_PORT=

# These variables are required - verify_payment_coverage throws if either is unset.

# MCP Server HTTP Port
# Port the MCP server (SSE / Streamable HTTP transports) listens on, bound to 0.0.0.0.
# Default: 8080
PORT=
