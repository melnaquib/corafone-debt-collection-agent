                "target": "capture_offer",
                "forward_condition": {
                    "type": "llm",
                    "condition": "identity verified and consumer consents to continue"
                }
            },
            "e2": {
                "source": "disclosure_identity",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "consumer refuses recording or cannot verify identity OR consumer says cease and desist / stop calling"
                }
            },
            "e3": {
                "source": "capture_offer",
                "target": "calc_negotiation",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e3a": {
                "source": "calc_negotiation",
                "target": "validate_floor",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e3b": {
                "source": "validate_floor",
                "target": "present_counter",
                "forward_condition": {
                    "type": "llm",
                    "condition": "meets_floor is true"
                }
            },
            "e3c": {
                "source": "validate_floor",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "meets_floor is false and consumer cannot increase offer"
                }
            },
            "e4": {
                "source": "present_counter",
                "target": "calc_negotiation_2",
                "forward_condition": {
                    "type": "llm",
                    "condition": "consumer counters with a different amount"
                }
            },
            "e4a": {
                "source": "calc_negotiation_2",
                "target": "validate_floor_2",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e4b": {
                "source": "validate_floor_2",
                "target": "present_counter",
                "forward_condition": {
                    "type": "llm",
                    "condition": "meets_floor is true"
                }
            },
            "e4c": {
                "source": "validate_floor_2",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "meets_floor is false"
                }
            },
            "e5": {
                "source": "present_counter",
                "target": "route_outcome",
                "forward_condition": {
                    "type": "llm",
                    "condition": "consumer accepts or clearly rejects entirely"
                }
            },
            "e6": {
                "source": "route_outcome",
                "target": "close_full_payment",
                "forward_condition": {
                    "type": "llm",
                    "condition": "plan_type is full_payment or plan_type is downpayment_plus_one"
                }
            },
            "e7": {
                "source": "route_outcome",
                "target": "close_settlement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "plan_type is settlement"
                }
            },
            "e8": {
                "source": "route_outcome",
                "target": "close_payment_plan",
                "forward_condition": {
                    "type": "llm",
                    "condition": "plan_type is payment_plan"
                }
            },
            "e9": {
                "source": "route_outcome",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "plan_type is below_floor or meets_floor is false"
                }
            },
            "e11": {
                "source": "capture_offer",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "consumer says cease and desist / stop calling"
                }
            },
            "e12": {
                "source": "present_counter",
                "target": "no_agreement",
                "forward_condition": {
                    "type": "llm",
                    "condition": "consumer says cease and desist / stop calling"
                }
            },
            "e13": {
                "source": "close_full_payment",
                "target": "send_outcome_node",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e14": {
                "source": "close_settlement",
                "target": "send_outcome_node",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e15": {
                "source": "close_payment_plan",
                "target": "send_outcome_node",
                "forward_condition": {
                    "type": "unconditional"
                }
            },
            "e16": {
                "source": "no_agreement",
                "target": "send_outcome_node",
                "forward_condition": {
                    "type": "unconditional"
                }
            }
        },
        "nodes": {
            "start_node": {
                "type": "start",
                "position": {
                    "x": 0,
                    "y": 0
                },
                "edge_order": [
                    "e0"
                ]
            },
            "disclosure_identity": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 300
                },
                "edge_order": [
                    "e1",
                    "e2"
                ],
                "conversation_config": {},
                "additional_prompt": "First, confirm the consumer consents to the recorded call. Then verify identity by asking for full name and date of birth. NEVER disclose any balance, amount owed, or account details until both consent and identity are confirmed. If the consumer greets you or makes small talk, respond warmly while guiding toward consent and identity verification. If they ask about their balance or account before identity verification, politely redirect: 'I'd be happy to help with that - I just need to verify your identity first. May I have your full name and date of birth?' If they refuse recording, offer a non-recorded callback and end.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Disclosure + Identity",
                "entry_behavior": "wait_for_user"
            },
            "capture_offer": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 600
                },
                "edge_order": [
                    "e3",
                    "e11"
                ],
                "conversation_config": {},
                "additional_prompt": "State the balance owed. Ask what the consumer can pay today. Anchor high: mention full payment as the first, preferred option before any discount. Capture their answer as consumer_offer — do not calculate anything yourself.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Capture Offer",
                "entry_behavior": "auto"
            },
            "calc_negotiation": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 900
                },
                "edge_order": [
                    "e3a"
                ],
                "conversation_config": {},
                "additional_prompt": "You MUST call the negotiate_calc tool now with the consumer's offered amount. Wait for the tool response - it will return a counter_offer, plan_type, and meets_floor. Do NOT say anything to the consumer yet - just call the tool and wait. Do NOT invent payment amounts yourself.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Calculate Counter-Offer (Round 1)",
                "entry_behavior": "auto"
            },
            "validate_floor": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 1050
                },
                "edge_order": [
                    "e3b",
                    "e3c"
                ],
                "conversation_config": {},
                "additional_prompt": "You MUST check the negotiate_calc tool result. Look at the meets_floor field in the response. If meets_floor=false, you MUST NOT accept the payment. Instead, explain that their offer is below the minimum requirement of 25% of the balance. State the specific minimum amount needed (the floor). Ask if they can increase their payment. Do NOT present any counter-offer if meets_floor is false. Only proceed to present_counter if meets_floor is true.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Validate Floor",
                "entry_behavior": "auto"
            },
            "present_counter": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 1200
                },
                "edge_order": [
                    "e4",
                    "e5",
                    "e12"
                ],
                "conversation_config": {},
                "additional_prompt": "State the counter-offer returned by the tool as your number, not one you invented. IMPORTANT: If negotiate_calc returned discount_percent and savings_amount, mention the value: 'If you can pay [counter_offer] today, you'll save [savings_amount] - that's [discount_percent]% off!' If they push back, either hold firm (restate the value of settling now and the discount savings, calmly, don't repeat the same line twice) or offer a creative trade (e.g. biweekly instead of monthly, or a different due date) for a higher amount, before ever discounting further. If they go quiet after you state the number, wait — do not fill silence by lowering it yourself.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Present Counter-Offer",
                "entry_behavior": "auto"
            },
            "calc_negotiation_2": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 1500
                },
                "edge_order": [
                    "e4a"
                ],
                "conversation_config": {},
                "additional_prompt": "Call the negotiate_calc tool again to calculate a second counter-offer. Wait for the result.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Calculate Counter-Offer (Round 2)",
                "entry_behavior": "auto"
            },
            "validate_floor_2": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 1650
                },
                "edge_order": [
                    "e4b",
                    "e4c"
                ],
                "conversation_config": {},
                "additional_prompt": "Check the negotiate_calc result from the second negotiation round. If meets_floor is false, explain that we've reached the minimum threshold and cannot go lower. Route to NO_AGREEMENT if they cannot meet the floor. If meets_floor is true, proceed to present the final counter-offer.",
                "additional_knowledge_base": [],
                "additional_tool_ids": [],
                "label": "Validate Floor (Round 2)",
                "entry_behavior": "auto"
            },
            "route_outcome": {
                "type": "override_agent",
                "position": {
                    "x": 0,
                    "y": 1800
                },
                "edge_order": [
                    "e6",
                    "e7",
                    "e8",
                    "e9"
