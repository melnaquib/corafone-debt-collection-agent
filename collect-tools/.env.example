# AWS Nitro Enclave Configuration
# Used for secure bank account verification via vsock

# Enclave CID (Context ID)
# The unique identifier for the AWS Nitro Enclave
# Example: 16
CREDIT_CHECK_TEE_CID=

# Enclave Port
# The port the enclave listens on for verification requests
# Example: 5000
CREDIT_CHECK_TEE_PORT=

# If these variables are not set, the system will use mock verification
# Mock returns random yes/no/cannot_confirm responses for testing
