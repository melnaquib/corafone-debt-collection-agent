{
    "type": "webhook",
    "name": "send_outcome",
    "description": "Sends the final call outcome to the downstream system. Call exactly once, at the end of the call, with exactly one of three outcome types: AGREEMENT_FULL_OR_DOWNPAYMENT, AGREEMENT_SETTLEMENT_OR_PLAN, or NO_AGREEMENT.",
    "response_timeout_secs": 20,
    "disable_interruptions": false,
    "interruption_mode": "allow",
    "force_pre_tool_speech": false,
    "pre_tool_speech": "auto",
    "assignments": [],
    "tool_call_sound_behavior": "auto",
    "tool_error_handling_mode": "auto",
    "dynamic_variables": {
        "dynamic_variable_placeholders": {}
    },
    "execution_mode": "immediate",
    "api_schema": {
        "request_headers": {
            "ngrok-skip-browser-warning": "1"
        },
        "url": "https://stretch-equation-ultimate.ngrok-free.dev/send_outcome",
        "method": "POST",
        "path_params_schema": {},
        "request_body_schema": {
            "type": "object",
            "required": [
                "outcome_type",
                "consent_confirmed"
            ],
            "description": "Final call result to log and route downstream — exactly one outcome type plus the agreed payment details, sent once at call end.",
            "properties": {
                "outcome_type": {
                    "type": "string",
                    "description": "One of exactly: AGREEMENT_FULL_OR_DOWNPAYMENT, AGREEMENT_SETTLEMENT_OR_PLAN, or NO_AGREEMENT, based on how the call concluded.",
                    "enum": [
                        "AGREEMENT_FULL_OR_DOWNPAYMENT",
                        "AGREEMENT_SETTLEMENT_OR_PLAN",
                        "NO_AGREEMENT"
                    ],
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "amount": {
                    "type": "number",
                    "description": "The final agreed payment amount, if any.",
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "plan_type": {
                    "type": "string",
                    "description": "One of: full_payment, downpayment_plus_one, settlement, payment_plan, or none.",
                    "enum": [
                        "full_payment",
                        "downpayment_plus_one",
                        "settlement",
                        "payment_plan"
                    ],
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "installments": {
                    "type": "number",
                    "description": "Number of payments agreed, if a plan was set up.",
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "frequency": {
                    "type": "string",
                    "description": "One of: weekly, biweekly, monthly, or n_a.",
                    "enum": [
                        "weekly",
                        "biweekly",
                        "monthly",
                        "n_a"
                    ],
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "consent_confirmed": {
                    "type": "boolean",
                    "description": "True only if the consumer gave explicit verbal confirmation of the amount, method, and date.",
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                },
                "notes": {
                    "type": "string",
                    "description": "Brief free-text summary of what happened, especially if no agreement was reached.",
                    "is_system_provided": false,
                    "dynamic_variable": "",
                    "allowed_values_dynamic_variable": "",
                    "constant_value": "",
                    "is_omitted": false
                }
            }
        },
        "content_type": "application/json",
        "auth_resolved_params": []
    }
}