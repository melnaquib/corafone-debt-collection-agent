  "workflow": {
    "edges": {
      "e0": {
        "source": "start_node",
        "target": "disclosure_identity",
        "forward_condition": {
          "type": "unconditional"
        }
      },
      "e1": {
        "source": "disclosure_identity",
        "target": "capture_offer",
        "forward_condition": {
          "type": "llm",
          "condition": "identity verified and consumer consents to continue"
        }
      },
      "e2": {
        "source": "disclosure_identity",
        "target": "no_agreement",
        "forward_condition": {
          "type": "llm",
          "condition": "consumer refuses recording or cannot verify identity OR consumer says cease and desist / stop calling"
        }
      },
      "e3": {
        "source": "capture_offer",
        "target": "calc_negotiation",
        "forward_condition": {
          "type": "unconditional"
        }
      },
      "e4": {
        "source": "present_counter",
        "target": "calc_negotiation_2",
        "forward_condition": {
          "type": "llm",
          "condition": "consumer counters with a different amount"
        }
      },
      "e5": {
        "source": "present_counter",
        "target": "route_outcome",
        "forward_condition": {
          "type": "llm",
          "condition": "consumer accepts or clearly rejects entirely"
        }
      },
      "e6": {
        "source": "route_outcome",
        "target": "close_full_payment",
        "forward_condition": {
          "type": "llm",
          "condition": "plan_type is full_payment or plan_type is downpayment_plus_one"
        }
      },
      "e7": {
        "source": "route_outcome",
        "target": "close_settlement",
        "forward_condition": {
          "type": "llm",
          "condition": "plan_type is settlement"
        }
      },
      "e8": {
        "source": "route_outcome",
        "target": "close_payment_plan",
        "forward_condition": {
          "type": "llm",
          "condition": "plan_type is payment_plan"
        }
      },
      "e9": {
        "source": "route_outcome",
        "target": "no_agreement",
        "forward_condition": {
          "type": "llm",
          "condition": "plan_type is below_floor or meets_floor is false"
        }
      },
      "e11": {
        "source": "capture_offer",
        "target": "no_agreement",
        "forward_condition": {
          "type": "llm",
          "condition": "consumer says cease and desist / stop calling"
        }
      },
      "e12": {
        "source": "present_counter",
        "target": "no_agreement",
        "forward_condition": {
          "type": "llm",
          "condition": "consumer says cease and desist / stop calling"
        }
      },
      "e13": {
        "source": "close_full_payment",
        "target": "send_outcome_node",
        "forward_condition": {
          "type": "unconditional"
        }
      },
      "e14": {
        "source": "close_settlement",
        "target": "send_outcome_node",
        "forward_condition": {
          "type": "unconditional"
        }
      },
      "e15": {
        "source": "close_payment_plan",
        "target": "send_outcome_node",
        "forward_condition": {
          "type": "unconditional"
        }
      },
      "e16": {
        "source": "no_agreement",
        "target": "send_outcome_node",
        "forward_condition": {
          "type": "unconditional"
        }
      }
    },
    "nodes": {
      "start_node": {
        "type": "start",
        "position": {
          "x": 0,
          "y": 0
        },
        "edge_order": [
          "e0"
        ]
      },
      "disclosure_identity": {
        "type": "override_agent",
        "position": {
          "x": 0,
          "y": 300
        },
        "edge_order": [
          "e1",
          "e2"
        ],
        "conversation_config": {},
        "additional_prompt": "Confirm the consumer consents to the recorded call. Then verify identity: ask for full name and date of birth. Do not disclose any balance or account detail until identity is confirmed. If they refuse recording, offer a non-recorded callback and end.\n\nCRITICAL: If consumer says 'cease and desist', 'stop calling', or requests no contact, IMMEDIATELY stop, acknowledge politely, confirm compliance, state debt is not erased, and route to NO_AGREEMENT without further discussion.",
        "additional_knowledge_base": [],
        "additional_tool_ids": [],
        "label": "Disclosure + Identity",
        "entry_behavior": "wait_for_user"
      },
      "capture_offer": {
        "type": "override_agent",
        "position": {
          "x": 0,
          "y": 600
        },
        "edge_order": [
          "e3",
          "e11"
        ],
        "conversation_config": {},
        "additional_prompt": "State the balance owed. Ask what the consumer can pay today. Anchor high: mention full payment as the first, preferred option before any discount. Capture their answer as consumer_offer \u2014 do not calculate anything yourself.\n\nCRITICAL: NEVER accept any amount without calling negotiate_calc first. If consumer says 'cease and desist' or requests no contact, stop immediately and route to NO_AGREEMENT.",
        "additional_knowledge_base": [],
        "additional_tool_ids": [],
        "label": "Capture Offer",
        "entry_behavior": "auto"
      },
      "calc_negotiation": {
        "type": "override_agent",
        "position": {
          "x": 0,
          "y": 900
        },
        "edge_order": [],
        "label": "Calculate Counter-Offer (Round 1)",
        "additional_prompt": "Call the negotiate_calc tool to calculate the counter-offer. Wait for the result. Do NOT invent or suggest any payment amounts yourself.\n\nCRITICAL: You MUST call this tool before presenting ANY counter-offer. Never skip this step.",
        "additional_tool_ids": [
          "tool_4401kx63h1wefdpbkdw4c8hx8ms8"
        ],
        "additional_knowledge_base": [],
        "entry_behavior": "auto",
        "conversation_config": {}
      },
      "present_counter": {
        "type": "override_agent",
        "position": {
          "x": 0,
          "y": 1200
        },
        "edge_order": [
          "e4",
          "e5",
          "e12"
        ],
        "conversation_config": {},
        "additional_prompt": "State the counter-offer returned by the tool as your number, not one you invented. If they push back, either hold firm (restate the value of settling now, calmly, don't repeat the same line twice) or offer a creative trade (e.g. biweekly instead of monthly, or a different due date) for a higher amount, before ever discounting further. If they go quiet after you state the number, wait \u2014 do not fill silence by lowering it yourself.\n\nCRITICAL: Only present amounts returned by negotiate_calc. If meets_floor=false, explain the 25% minimum calmly. If consumer says 'cease and desist', stop and route to NO_AGREEMENT.",
        "additional_knowledge_base": [],
        "additional_tool_ids": [],
        "label": "Present Counter-Offer",
        "entry_behavior": "auto"
      },
      "calc_negotiation_2": {
        "type": "override_agent",
        "position": {
          "x": 0,
